l","onMouseEnter","onMouseLeave","width","height","margin","top","right","left","bottom","id","g","x1","y1","x2","y2","offset","stopColor","stopOpacity","stroke","vertical","dataKey","tick","fill","fontSize","axisLine","tickLine","tickFormatter","v","content","s","type","strokeWidth","dot","activeDot","r","opacity","transition"],"sources":["C:/Users/Steve Junior/Desktop/test/src/components/RevenueChart.js"],"sourcesContent":["import React, { useState } from 'react';\r\nimport { AreaChart, Area, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from 'recharts';\r\nimport './RevenueChart.css';\r\n\r\nconst data = [\r\n  { name: 'Mon', revenue: 18400, expenses: 11200, profit: 7200 },\r\n  { name: 'Tue', revenue: 22100, expenses: 13400, profit: 8700 },\r\n  { name: 'Wed', revenue: 19800, expenses: 12100, profit: 7700 },\r\n  { name: 'Thu', revenue: 31200, expenses: 15600, profit: 15600 },\r\n  { name: 'Fri', revenue: 28900, expenses: 14300, profit: 14600 },\r\n  { name: 'Sat', revenue: 35400, expenses: 16800, profit: 18600 },\r\n  { name: 'Sun', revenue: 41200, expenses: 18900, profit: 22300 },\r\n];\r\n\r\nconst CustomTooltip = ({ active, payload, label }) => {\r\n  if (!active || !payload?.length) return null;\r\n  return (\r\n    <div className=\"chart-tooltip\">\r\n      <div className=\"tooltip-label\">{label}</div>\r\n      {payload.map(p => (\r\n        <div key={p.name} className=\"tooltip-row\">\r\n          <span className=\"tooltip-dot\" style={{ background: p.color }} />\r\n          <span className=\"tooltip-name\">{p.name}</span>\r\n          <span className=\"tooltip-val\">${(p.value / 1000).toFixed(1)}k</span>\r\n        </div>\r\n      ))}\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default function RevenueChart() {\r\n  const [hovered, setHovered] = useState(null);\r\n  return (\r\n    <div className=\"card revenue-chart\">\r\n      <div className=\"chart-header\">\r\n        <div>\r\n          <div className=\"card-title\">Revenue Overview</div>\r\n          <div className=\"chart-total\">$197,000 <span className=\"chart-period\">this week</span></div>\r\n        </div>\r\n        <div className=\"chart-legend\">\r\n          {[{ key: 'revenue', color: '#7c6af7', label: 'Revenue' }, { key: 'expenses', color: '#f97316', label: 'Expenses' }, { key: 'profit', color: '#22d3ee', label: 'Profit' }].map(l => (\r\n            <div key={l.key} className={`legend-item ${hovered && hovered !== l.key ? 'dim' : ''}`} onMouseEnter={() => setHovered(l.key)} onMouseLeave={() => setHovered(null)}>\r\n              <span className=\"legend-dot\" style={{ background: l.color }} />\r\n              {l.label}\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </div>\r\n      <ResponsiveContainer width=\"100%\" height={220}>\r\n        <AreaChart data={data} margin={{ top: 4, right: 4, left: -20, bottom: 0 }}>\r\n          <defs>\r\n            {[{ id: 'revenue', color: '#7c6af7' }, { id: 'expenses', color: '#f97316' }, { id: 'profit', color: '#22d3ee' }].map(g => (\r\n              <linearGradient key={g.id} id={`grad-${g.id}`} x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\r\n                <stop offset=\"0%\" stopColor={g.color} stopOpacity={0.25} />\r\n                <stop offset=\"100%\" stopColor={g.color} stopOpacity={0} />\r\n              </linearGradient>\r\n            ))}\r\n          </defs>\r\n          <CartesianGrid stroke=\"rgba(255,255,255,0.04)\" vertical={false} />\r\n          <XAxis dataKey=\"name\" tick={{ fill: 'rgba(240,240,245,0.35)', fontSize: 11 }} axisLine={false} tickLine={false} />\r\n          <YAxis tick={{ fill: 'rgba(240,240,245,0.35)', fontSize: 11 }} axisLine={false} tickLine={false} tickFormatter={v => `$${v / 1000}k`} />\r\n          <Tooltip content={<CustomTooltip />} />\r\n          {[{ key: 'revenue', color: '#7c6af7' }, { key: 'expenses', color: '#f97316' }, { key: 'profit', color: '#22d3ee' }].map(s => (\r\n            <Area key={s.key} type=\"monotone\" dataKey={s.key} stroke={s.color} strokeWidth={2} fill={`url(#grad-${s.key})`} dot={false} activeDot={{ r: 4, strokeWidth: 0, fill: s.color }} opacity={hovered && hovered !== s.key ? 0.2 : 1} style={{ transition: 'opacity 0.2s' }} />\r\n          ))}\r\n        </AreaChart>\r\n      </ResponsiveContainer>\r\n    </div>\r\n  );\r\n}"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,QAAQ,KAAQ,OAAO,CACvC,OAASC,SAAS,CAAEC,IAAI,CAAEC,KAAK,CAAEC,KAAK,CAAEC,aAAa,CAAEC,OAAO,CAAEC,mBAAmB,KAAQ,UAAU,CACrG,MAAO,oBAAoB,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAE5B,KAAM,CAAAC,IAAI,CAAG,CACX,CAAEC,IAAI,CAAE,KAAK,CAAEC,OAAO,CAAE,KAAK,CAAEC,QAAQ,CAAE,KAAK,CAAEC,MAAM,CAAE,IAAK,CAAC,CAC9D,CAAEH,IAAI,CAAE,KAAK,CAAEC,OAAO,CAAE,KAAK,CAAEC,QAAQ,CAAE,KAAK,CAAEC,MAAM,CAAE,IAAK,CAAC,CAC9D,CAAEH,IAAI,CAAE,KAAK,CAAEC,OAAO,CAAE,KAAK,CAAEC,QAAQ,CAAE,KAAK,CAAEC,MAAM,CAAE,IAAK,CAAC,CAC9D,CAAEH,IAAI,CAAE,KAAK,CAAEC,OAAO,CAAE,KAAK,CAAEC,QAAQ,CAAE,KAAK,CAAEC,MAAM,CAAE,KAAM,CAAC,CAC/D,CAAEH,IAAI,CAAE,KAAK,CAAEC,OAAO,CAAE,KAAK,CAAEC,QAAQ,CAAE,KAAK,CAAEC,MAAM,CAAE,KAAM,CAAC,CAC/D,CAAEH,IAAI,CAAE,KAAK,CAAEC,OAAO,CAAE,KAAK,CAAEC,QAAQ,CAAE,KAAK,CAAEC,MAAM,CAAE,KAAM,CAAC,CAC/D,CAAEH,IAAI,CAAE,KAAK,CAAEC,OAAO,CAAE,KAAK,CAAEC,QAAQ,CAAE,KAAK,CAAEC,MAAM,CAAE,KAAM,CAAC,CAChE,CAED,KAAM,CAAAC,aAAa,CAAGC,IAAA,EAAgC,IAA/B,CAAEC,MAAM,CAAEC,OAAO,CAAEC,KAAM,CAAC,CAAAH,IAAA,CAC/C,GAAI,CAACC,MAAM,EAAI,EAACC,OAAO,SAAPA,OAAO,WAAPA,OAAO,CAAEE,MAAM,EAAE,MAAO,KAAI,CAC5C,mBACEX,KAAA,QAAKY,SAAS,CAAC,eAAe,CAAAC,QAAA,eAC5Bf,IAAA,QAAKc,SAAS,CAAC,eAAe,CAAAC,QAAA,CAAEH,KAAK,CAAM,CAAC,CAC3CD,OAAO,CAACK,GAAG,CAACC,CAAC,eACZf,KAAA,QAAkBY,SAAS,CAAC,aAAa,CAAAC,QAAA,eACvCf,IAAA,SAAMc,SAAS,CAAC,aAAa,CAACI,KAAK,CAAE,CAAEC,UAAU,CAAEF,CAAC,CAACG,KAAM,CAAE,CAAE,CAAC,cAChEpB,IAAA,SAAMc,SAAS,CAAC,cAAc,CAAAC,QAAA,CAAEE,CAAC,CAACb,IAAI,CAAO,CAAC,cAC9CF,KAAA,SAAMY,SAAS,CAAC,aAAa,CAAAC,QAAA,EAAC,GAAC,CAAC,CAACE,CAAC,CAACI,KAAK,CAAG,IAAI,EAAEC,OAAO,CAAC,CAAC,CAAC,CAAC,GAAC,EAAM,CAAC,GAH5DL,CAAC,CAACb,IAIP,CACN,CAAC,EACC,CAAC,CAEV,CAAC,CAED,cAAe,SAAS,CAAAmB,YAAYA,CAAA,CA